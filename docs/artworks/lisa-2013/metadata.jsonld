    {
      "@type": "DefinedTermSet",
      "@id": "#epistemology-of-the-image",
      "name": "Epistemology of the Image",
      "description": "Theoretical concepts developed by Alexandre Mury in the field of contemporary image, post-conceptual practice and machine-readable art documentation."
    },
    {
      "@type": "DefinedTerm",
      "@id": "#hybrid-dramaturgies",
      "name": "Hybrid Dramaturgies",
      "alternateName": [
        "Dramaturgias Híbridas"
      ],
      "description": "Conceptual operation in which image, body, text, voice, music, staging, duration and documentation produce meaning through overlapping temporal and symbolic layers.",
      "url": "https://id.alexandremury.art/concept/hybrid-dramaturgies/",
      "inDefinedTermSet": {
        "@id": "#epistemology-of-the-image"
      }
    },
    {
      "@type": "DefinedTerm",
      "@id": "#self-implicative-method",
      "name": "Self-Implicative Method",
      "alternateName": [
        "Método Autoimplicativo"
      ],
      "description": "Methodological and artistic operation in which the artist, critic or interpreter becomes implicated in the very image, discourse or system being activated.",
      "url": "https://id.alexandremury.art/concept/self-implicative-method/",
      "inDefinedTermSet": {
        "@id": "#epistemology-of-the-image"
      }
    },
    {
      "@type": "DefinedTerm",
      "@id": "#imagetic-disappropriation",
      "name": "Imagetic Disappropriation",
      "alternateName": [
        "Desapropriação Imagética",
        "Image Disappropriation"
      ],
      "description": "Artistic operation that displaces an image from its symbolic origin to establish autonomous signification, distinct from appropriation art through symbolic autonomy rather than appropriation.",
      "sameAs": "https://www.wikidata.org/wiki/Q136744908",
      "url": "https://id.alexandremury.art/concept/imagetic-disappropriation/",
      "inDefinedTermSet": {
        "@id": "#epistemology-of-the-image"
      }
    },
    {
      "@type": "DefinedTerm",
      "@id": "#cultural-autophagy",
      "name": "Cultural Autophagy",
      "alternateName": [
        "Autofagia Cultural"
      ],
      "description": "Artistic and epistemological process in which a culture turns its anthropophagic gesture inward, digesting its own myths, images and discourses.",
      "sameAs": "https://www.wikidata.org/wiki/Q136831273",
      "url": "https://id.alexandremury.art/concept/cultural-autophagy/",
      "inDefinedTermSet": {
        "@id": "#epistemology-of-the-image"
      }
    },
