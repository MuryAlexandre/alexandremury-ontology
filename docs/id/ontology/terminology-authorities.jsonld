  "@graph": [
    {
      "@type": "crm:E29_Design_or_Procedure",
      "@id": "https://www.alexandremury.art/id/ontology/terminology-authorities",
      "dct:title": [
        {
          "@value": "AMO Terminology Authorities & Indexing Strategy",
          "@language": "en"
        },
        {
          "@value": "Autoridades de Terminologia & Estratégia de Indexação AMO",
          "@language": "pt"
        }
      ],
      "dct:creator": {
        "@id": "https://www.alexandremury.art/id/person/alexandre-mury"
      },
      "dct:issued": "2026-06-19",
      "dct:description": [
        {
          "@value": "Comprehensive registry of terms, linguistic origin, sources, and indexing strategy for the Alexandre Mury Ontology (AMO). This document establishes the authoritative forms of all proprietary concepts and ensures consistency across multilingual representation and machine-readable processing.",
          "@language": "en"
        },
        {
          "@value": "Registro abrangente de termos, origem linguística, fontes e estratégia de indexação para a Ontologia Alexandre Mury (AMO). Este documento estabelece as formas autorizadas de todos os conceitos proprietários e garante consistência na representação multilíngue e no processamento legível por máquinas.",
          "@language": "pt"
        }
      ],
      "amo:indexingPrinciples": {
        "@type": "crm:E29_Design_or_Procedure",
        "amo:principle_pt": "Preserves epistemological specificity, original coinage documentation, and human readability in Portuguese",
        "amo:principle_en": "Enables global algorithmic indexing, Wikidata alignment, Zenodo DOI circulation, and machine-readable theory distribution",
        "amo:duality_model": "Intentional bilingual register: both languages maintain equal ontological authority but operate in distinct computational and discursive registers",
        "amo:canonicity": "English URIs and prefLabels serve as canonical for RDF/Linked Data processing; Portuguese labels preserve epistemological genealogy and authorial intent"
      }
    },
