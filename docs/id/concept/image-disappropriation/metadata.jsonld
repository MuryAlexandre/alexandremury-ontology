  "@graph": [
    {
      "@id": "am:concept/desapropriacao-imagetica",
      "@type": [
        "crm:E28_Conceptual_Object",
        "skos:Concept"
      ],
      "skos:prefLabel": [
        { "@language": "pt-br", "@value": "Desapropriação Imagética" },
        { "@language": "pt-pt", "@value": "Expropriação Imagética" },
        { "@language": "en", "@value": "Image Disappropriation" },
        { "@language": "fr", "@value": "Désappropriation Iconique" },
        { "@language": "de", "@value": "Bildliche Enteignung" },
        { "@language": "es", "@value": "Desapropiación Icónica" },
        { "@language": "it", "@value": "Disappropriazione Iconica" },
        { "@language": "ar", "@value": "نزع الملكية التصويري" },
        { "@language": "ja", "@value": "脱アプロプリエーション" },
        { "@language": "ru", "@value": "Образная дизаппроприация" }
      ],
      "skos:altLabel": [
        { "@language": "ru", "@value": "Образная депроприация" }
      ],
      "skos:definition": [
        {
          "@language": "pt",
          "@value": "A desapropriação imagética nomeia a operação pela qual uma imagem é deslocada de seu contexto simbólico de origem sem intenção de reproduzi-lo, citá-lo ironicamente ou negar sua validade histórica. A imagem desprende-se de sua matriz e conquista autonomia simbólica própria."
        },
        {
          "@language": "en",
          "@value": "Image disappropriation names the operation by which an image is displaced from its symbolic origin without the intention to reproduce it, quote it ironically, or negate its historical significance. Rather, disappropriation establishes autonomous signification through displacement, creating new meanings that exist independently of the source image."
        }
      ],
      "skos:scopeNote": [
        {
          "@language": "pt",
          "@value": "O conceito aplica-se a qualquer operação artística em que a relação com uma imagem preexistente seja o motor de uma autonomia simbólica nova, e em que o resultado não possa ser descrito adequadamente como reprodução, paródia, homenagem ou crítica direta."
        }
      ],
      "skos:note": [
        {
          "@language": "pt",
          "@value": "DISTINÇÃO COM RESSIGNIFICAÇÃO: A ressignificação altera o que a imagem significa no campo semântico; a desapropriação altera de onde a imagem pode significar, rompendo o vínculo estrutural de subordinação com o arquivo ou matriz de origem."
        },
        {
          "@language": "pt",
          "@value": "GENEALOGIA: Deriva dialeticamente da disappropriazione de Giorgio Agamben (Creazione e anarchia, 2017; Disappropriata materia / Res amissa, 1991). Na AMO, o termo é deslocado da subjetividade da criação para a ontologia e autonomia do objeto-imagem."
        }
      ],
      "skos:inScheme": { "@id": "am:scheme/epistemologia-da-imagem" },
      "schema:author": { "@id": "am:person/alexandre-mury" },
      "schema:citation": [
        { "@id": "https://doi.org" },
        { "@id": "https://doi.org" },
        { "@id": "https://doi.org" }
      ],
      "skos:narrower": [
        { "@id": "am:concept/cultural-autophagy" }
      ],
      "skos:related": [
        { "@id": "am:concept/critical-fiction" },
        { "@id": "am:concept/theoretical-disappropriation" },
        { "@id": "am:relation/visual-intertextuality" },
        { "@id": "am:concept/ressignificacao" }
      ],
