    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "am:concept/desapropriacao-imagetica",
      "@type": [
        "crm:E28_Conceptual_Object",
        "skos:Concept"
      ],
      "skos:prefLabel": [
        { "@language": "pt-br", "@value": "Desapropriação Imagética" },
        { "@language": "pt-pt", "@value": "Expropriação Imagética" },
        { "@language": "en", "@value": "Image Disappropriation" },
        { "@language": "fr", "@value": "Désappropriation Iconique" },
        { "@language": "de", "@value": "Bildliche Enteignung" },
        { "@language": "es", "@value": "Desapropiación Icónica" },
        { "@language": "it", "@value": "Disappropriazione Iconica" },
        { "@language": "ar", "@value": "نزع الملكية التصويري" },
        { "@language": "ja", "@value": "脱アプロプリエーション" },
        { "@language": "ru", "@value": "Образная дизаппроприация" }
      ],
      "skos:altLabel": [
        { "@language": "ru", "@value": "Образная депроприация" }
      ],
      "skos:definition": [
        {
          "@language": "en",
          "@value": "Image disappropriation names the operation by which an image is displaced from its symbolic origin without the intention to reproduce it, quote it ironically, or negate its historical significance. Rather, disappropriation establishes autonomous signification through displacement, creating new meanings that exist independently of the source image."
        }
      ],
      "skos:scopeNote": [
        {
          "@language": "en",
          "@value": "This concept applies to artistic operations where the relationship with a pre-existing image acts as a motor for new symbolic autonomy, beyond parody or homage."
        }
      ],
      "skos:note": [
        {
          "@language": "en",
          "@value": "HISTORIOGRAPHY: Distinguished from artistic appropriation (Duchamp, Levine, Prince) which operates through irony or institutional commentary. In disappropriation, the source work is not quoted but displaced, allowing the new work to establish its own symbolic field. Related to but distinct from concepts of reinterpretation, citation, and intertextuality."
        }
      ],
      "skos:inScheme": { "@id": "am:scheme/epistemologia-da-imagem" },
      "schema:author": { "@id": "am:person/alexandre-mury" },
      "schema:citation": [
        { "@id": "https://doi.org/10.5281/zenodo.17548245" },
        { "@id": "https://doi.org/10.5281/zenodo.17458777" },
        { "@id": "https://doi.org/10.5281/zenodo.17637511" }
      ],
      "skos:narrower": [
        { "@id": "am:concept/cultural-autophagy" }
      ],
      "skos:related": [
        { "@id": "am:concept/critical-fiction" },
        { "@id": "am:concept/theoretical-disappropriation" },
        { "@id": "am:relation/visual-intertextuality" }
      ],
      "amo:hasInterpretiveRegime": [
        { "@id": "am:relation/reinterpretation" },
        { "@id": "am:relation/performative-reenactment" },
        { "@id": "am:relation/self-representation" }
      ],
      "rdfs:isDefinedBy": { "@id": "amo:Ontology" }
    },
