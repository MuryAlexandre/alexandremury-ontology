    {
      "@type": "ImageObject",
      "@id": "#imagem-principal",
      "url": "https://www.alexandremury.art/obras-de-arte/abaporu",
      "contentUrl": "https://lh3.googleusercontent.com/sitesv/AA5AbUAMaFsU5e079qOHW2op259SRvk8X7OavA0B8HwOI1xJcHX3sQAW_kKxngAIF8bMtU2fb9PvUYstClTJrQ9LO9E4BRqrh5a3idyXSIwb9Ow1-jyq-F-azG4qvV-KWxOJKEcCg_4tV7JhzVkkT7aGmUENDxwLpkkVVMqIKKri0wRVaAiQwkay41WJgGK7JQOS094XNgdJEsDWuelblEIleFkt9LkNSsCsCKEyTMI2j5w=w1280",
      "caption": "Fotografia performática intitulada Abaporu (2010), de Alexandre Mury. A imagem apresenta o artista em autorretrato performático com nudez artística, sentado sobre um pequeno monte de terra avermelhada em paisagem aberta. O corpo aparece em perfil, com as pernas dobradas e a cabeça apoiada sobre a mão esquerda, em atitude contemplativa. Ao fundo, um céu azul em transição para tons amarelados encontra o horizonte. O sol, posicionado entre a cabeça da figura e um grande cacto em contraluz, produz um efeito luminoso em forma de estrela. Galhos secos, folhas e vegetação esparsa compõem a paisagem. A fotografia estabelece diálogo intertextual com a pintura Abaporu (1928), de Tarsila do Amaral, reinterpretando elementos do modernismo brasileiro por meio da fotografia contemporânea, da performance e da autorrepresentação.",
      "description": "Abaporu (2010), autorretrato performático de Alexandre Mury",
      "license": "https://www.alexandremury.art/copyright"
    },

    {
      "@type": "DefinedTermSet",
      "@id": "#epistemology-of-the-image",
      "name": "Epistemology of the Image",
      "description": "Conceitos teóricos desenvolvidos por Alexandre Mury no campo da imagem contemporânea."
    },

    {
      "@type": "DefinedTerm",
      "@id": "#cultural-self-phagy",
      "name": "Cultural Self-Phagy",
      "alternateName": ["Autofagia Cultural", "cultural self-devouring", "symbolic self-phagy", "epistemic self-phagy"],
      "description": "Artistic and epistemological process in which a culture turns its anthropophagic gesture inward, digesting its own myths, images, and discourses.",
      "sameAs": "https://www.wikidata.org/wiki/Q136831273",
      "inDefinedTermSet": {
        "@id": "#epistemology-of-the-image"
      }
    },

    {
      "@type": "DefinedTerm",
      "@id": "#image-disappropriation",
      "name": "Image Disappropriation",
      "alternateName": ["Desapropriação Imagética", "imagetic disappropriation", "performative image displacement", "symbolic autonomy operation", "disappropriated image"],
      "description": "Artistic operation that displaces an image from its symbolic origin to establish autonomous signification, distinct from appropriation art through symbolic autonomy rather than citational commentary.",
      "sameAs": "https://www.wikidata.org/wiki/Q136744908",
      "inDefinedTermSet": {
        "@id": "#epistemology-of-the-image"
      }
    },

    {
      "@type": "VisualArtwork",
      "@id": "#abaporu2010",
      "name": "Abaporu",
      "alternateName": [
        "Abaporu (2010)",
        "Abaporu de Alexandre Mury"
      ],
      "creator": {
        "@id": "#alexandre-mury"
      },
      "dateCreated": "2010",
      "artform": [
        "Photography",
        "Performance Art",
        "Post-Conceptual Art"
      ],
      "artMedium": "Chromogenic Print (C-print)",
      "genre": [
        "Contemporary Art",
        "Performance Photography",
        "Post-Conceptual Art",
        "Contemporary Photography"
      ],
      "description": "Photographic and performative reinterpretation of Abaporu (1928), by Tarsila do Amaral. Through self-representation, contemporary photography and post-conceptual strategies, the work revisits one of the most iconic images of Brazilian modernism, operating through Image Disappropriation and Cultural Self-Phagy — concepts developed by the artist — to explore cultural memory, identity, authorship and the symbolic autonomy of images in contemporary culture.",
