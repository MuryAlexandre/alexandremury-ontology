      "amo:termsScopeNote": {
        "@language": "en",
        "@value": "The authorial terms listed in this ontology record identify the current terminology field of A.M.O. They are not exhaustive, closed, or definitive. Concepts may be added, deferred, renamed, reorganized, or withdrawn as the ontology develops, without altering the general namespace policy or the autonomy of already published records."
      },
      "amo:namespacePolicy": {
        "@language": "en",
        "@value": "English-language slugs are used for stability, interoperability, and linked data processing. Portuguese labels preserve the epistemological genealogy, original coinage, and authorial intent of the concepts. Canonical entity URIs use a final slash."
      },
      "amo:publicationModel": {
        "@language": "en",
        "@value": "A.M.O. records are published progressively. Each canonical record may contain a human-readable index.html and a corresponding metadata.jsonld. Aggregate files such as ontology.jsonld, concepts.jsonld, RDF/Turtle files, and CIDOC CRM serializations are deferred until individual records and the terminology authority are stable."
      },
      "amo:doesNotDo": [
        "does not prescribe a single interpretation of the works",
        "does not replace CIDOC CRM, SKOS, Schema.org, Wikidata, DOI records, museum records, scholarly references, or external criticism",
        "does not convert artistic practice into a closed theoretical doctrine",
        "does not treat external sources, interlocutors, genealogies, or analogies as the authorial origin of its concepts",
        "does not require every future artwork, relation, or concept to be manually listed on the ontology page in order to be interoperable"
      ],
      "amo:preferredArtworkConceptRelation": [
        "amo:mobilizesConcept",
        "amo:hasOperationalInstance"
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://id.alexandremury.art/ontology/"
      }
