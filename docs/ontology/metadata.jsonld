    {
      "@id": "https://id.alexandremury.art/scheme/regimes/",
      "@type": [
        "schema:DefinedTermSet",
        "skos:ConceptScheme"
      ],
      "schema:name": "Relational regimes",
      "schema:alternateName": [
        "Modes of relation",
        "Regimes de Relação"
      ],
      "schema:url": "https://id.alexandremury.art/scheme/regimes/",
      "schema:creator": {
        "@id": "https://id.alexandremury.art/person/alexandre-mury/"
      },
      "skos:prefLabel": [
        {
          "@language": "en",
          "@value": "Relational regimes"
        },
        {
          "@language": "en",
          "@value": "Modes of relation"
        },
        {
          "@language": "pt-BR",
          "@value": "Regimes de Relação"
        }
      ],
      "skos:definition": {
        "@language": "en",
        "@value": "Controlled vocabulary for relational terms describing how artworks relate to prior images, bodies, figures, traditions, archives, symbolic structures, or cultural signs. These terms do not prescribe interpretation; they describe modes of relation."
      },
      "amo:preferredProperty": "amo:hasRelationalRegime",
      "amo:termURIPattern": "https://id.alexandremury.art/relation/{relation-slug}/",
      "amo:termsScopeNote": {
        "@language": "en",
        "@value": "Relational terms may include reenactment, self-representation, visual citation, internal critical digestion, metadata activation, polysemic articulation, and other modes of relation. The list is intentionally not exhaustive."
      },
      "rdfs:isDefinedBy": {
        "@id": "https://id.alexandremury.art/ontology/"
      }
    },
