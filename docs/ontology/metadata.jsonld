      "dct:issued": "2026-06-19",
      "dct:modified": "2026-07-09",
      "amo:baseURI": "https://id.alexandremury.art/",
      "amo:namespace": "https://id.alexandremury.art/ontology/",
      "amo:preferredPrefix": "amo",
      "schema:description": "A.M.O. — Alexandre Mury Ontology is an authorial ontology, terminology authority, and knowledge organization system developed by Alexandre Mury to document artworks, concepts, relational terms, terminology authorities, and semantic relations emerging from his artistic and theoretical practice. It works in dialogue with CIDOC CRM, SKOS, Schema.org, JSON-LD, RDF, Wikidata, DOI-based scholarly circulation, and linked open data practices without replacing them.",
      "schema:disambiguatingDescription": "A.M.O. is not a closed theoretical doctrine, a substitute for CIDOC CRM, SKOS, Schema.org, Wikidata, museum records, DOI records, scholarly references, or external criticism. It is an authorial semantic layer designed to make artistic thought, artworks, concepts, and relations more legible and interoperable without prescribing a single interpretation of the works.",
      "schema:keywords": [
        "A.M.O.",
        "Alexandre Mury Ontology",
        "Ontologia Alexandre Mury",
        "Alexandre Mury",
        "authorial ontology",
        "terminology authority",
