      "amo:hasDialogueSource": [
        "Aby Warburg — survival, anachronism, visual memory, and afterlife of images",
        "Georges Didi-Huberman — survival of forms, montage, anachronism, and temporal complexity of images",
        "Roland Barthes — image as a polysemic field",
        "Umberto Eco — openness of the work without reduction to interpretive relativism",
        "Paul Ricoeur — hermeneutics and surplus of meaning",
